# Xano base URL, for example:
# https://x8ki-letl-twmt.n7.xano.io/api:abc123
XANO_BASE_URL=

# Optional bearer token if your Xano endpoint requires auth.
XANO_API_KEY=

# Endpoint path for fetching logged-in user profile (used by /api/bootstrap).
# Example: /auth/me
XANO_USER_ENDPOINT=

# Endpoint path for creating shift entries (used by /api/shift-entries).
# Example: /shift_entries
XANO_SHIFT_ENTRIES_ENDPOINT=
